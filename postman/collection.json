    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register Student",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"أحمد\",\n  \"middle_name\": \"محمد\",\n  \"last_name\": \"علي\",\n  \"national_id\": \"29901011234567\",\n  \"personal_email\": \"student@example.com\",\n  \"password\": \"SecurePass123\",\n  \"gender\": \"male\",\n  \"street_address\": \"القاهرة\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/auth/register",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "تسجيل طالب جديد (عام). غيّر national_id و personal_email لقيم غير مستخدمة في قاعدة البيانات."
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    if (response.token && response.user) {",
                  "        const user = response.user;",
                  "        if (user.role === 'ADMIN') {",
                  "            pm.collectionVariables.set('ADMIN_TOKEN', response.token);",
                  "        } else if (user.role === 'ADVISOR') {",
                  "            pm.collectionVariables.set('ADVISOR_TOKEN', response.token);",
                  "        } else if (user.role === 'STUDENT') {",
                  "            pm.collectionVariables.set('STUDENT_TOKEN', response.token);",
                  "        }",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"12345678901234\",\n  \"password\": \"YourPasswordHere123\",\n  \"role\": \"ADMIN\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/auth/login",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Use this request to login as any role (ADMIN/ADVISOR/STUDENT).\n- Update `identifier` and `password` with real credentials from your seed data.\n- On success, the script will automatically set `ADMIN_TOKEN`, `ADVISOR_TOKEN`, or `STUDENT_TOKEN` collection variables based on the returned user role.\n- Other requests in this collection reference these variables in the `Authorization` header."
          },
          "response": []
        },
