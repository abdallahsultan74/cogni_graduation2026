# Server
# محليًا: PORT اختياري. على Vercel لا تضبط PORT يدويًا — المنصة تحقنه.
PORT=5000
# محليًا: development. على الإنتاج (Vercel/Render): production
NODE_ENV=development

# Database (PostgreSQL). Supabase: pooler URL + direct URL for migrations — see prisma/schema.prisma
DATABASE_URL=postgresql://user:password@localhost:5432/cogni_advisor
DIRECT_URL=postgresql://user:password@localhost:5432/cogni_advisor

# JWT — استخدم قيمة عشوائية طويلة في الإنتاج (لا تترك القيمة الافتراضية)
JWT_SECRET=your-secret-key-change-in-production

# CORS - comma-separated list of allowed origins (use * for all in development)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Optional: Log level (info, debug, error, http)
# LOG_LEVEL=info
