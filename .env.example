# Server
# محليًا: PORT اختياري. على Vercel لا تضبط PORT يدويًا — المنصة تحقنه.
PORT=5000
# محليًا: development. على الإنتاج (Vercel/Render): production
NODE_ENV=development

# Database (PostgreSQL). Supabase: pooler URL + direct URL for migrations — see prisma/schema.prisma
DATABASE_URL=postgresql://user:password@localhost:5432/cogni_advisor
DIRECT_URL=postgresql://user:password@localhost:5432/cogni_advisor

# Password reset email (Resend — required to SEND OTP)
# Get a key at https://resend.com — in dev without a key, OTP is logged in the backend console.
RESEND_API_KEY=
# Dev: use onboarding@resend.dev (Resend test sender). Production: your verified domain.
EMAIL_FROM=onboarding@resend.dev
FRONTEND_URL=http://localhost:3000

# Mailboxlayer — validates personal email before send (does NOT send mail)
# https://mailboxlayer.com/dashboard
MAILBOXLAYER_ACCESS_KEY=

# Supabase project settings (legacy OTP forgot-password flow)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# JWT — استخدم قيمة عشوائية طويلة في الإنتاج (لا تترك القيمة الافتراضية)
JWT_SECRET=your-secret-key-change-in-production

# Default admin bootstrap (created only if no admin exists)
DEFAULT_ADMIN_EMAIL=admin@admin.eelu.edu.eg
DEFAULT_ADMIN_PASSWORD=Admin@12345
DEFAULT_ADMIN_NATIONAL_ID=10000000000000

# CORS - comma-separated list of allowed origins (use * for all in development)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Cogni Advisor AI (local Flask on 7860 or Hugging Face Space)
COGNI_ADVISOR_AI_ENABLED=1
COGNI_ADVISOR_AI_BASE_URL=http://localhost:7860
COGNI_ADVISOR_AI_TIMEOUT_MS=60000
# Optional: override local catalog snapshot path (single file legacy mode)
# Track-specific catalogs: courses_it.json / courses_ai.json under recommendation/data/
# Regenerate from StudyPlanner: npx tsx src/scripts/sync_studyplanner_catalog.ts
# COGNI_ADVISOR_AI_CATALOG_PATH=cogni-advisor-ai/GP/recommendation/data/courses.json

# Optional: Log level (info, debug, error, http)
# LOG_LEVEL=info

# ── Docker (backend + AI) ──
# docker compose up --build
# With local Postgres: docker compose -f docker-compose.yml -f docker-compose.local-db.yml up --build
# Backend: http://localhost:5000  |  AI: http://localhost:7860
# Backend Web Service: build = npm ci && npm run build && npx prisma migrate deploy
# AI Web Service: Docker from cogni-advisor-ai/GP (plan: standard recommended)
# Set COGNI_ADVISOR_AI_BASE_URL to the AI service RENDER_EXTERNAL_URL
