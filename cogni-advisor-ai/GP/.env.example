# Use ONE provider for LLM calls
GEMINI_API_KEY=
# OPENROUTER_API_KEY=

# Optional provider/model overrides
# LLM_PROVIDER=gemini
# Use gemini-flash-latest (do NOT use gemini-1.5-* — deprecated/shutdown)
GEMINI_MODEL=gemini-flash-latest
# OPENROUTER_MODEL=deepseek/deepseek-chat-v3.1:free

# Runtime config
EELU_SECRET_KEY=change-me
EELU_HOST=0.0.0.0
EELU_PORT=7860
EELU_PRELOAD=1
